# PostgreSQL connection string used by Prisma (migrations + client).
#
# Local dev example (Postgres running on your machine / docker):
#   DATABASE_URL="postgresql://postgres:mysecretpassword@localhost:5432/postgres"
#
# Hosted providers (Neon / Supabase / Render / Railway) usually require SSL,
# so include ?sslmode=require at the end:
#   DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"
#
# In production (Render) this is set as a service Environment Variable, not a file.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME"
