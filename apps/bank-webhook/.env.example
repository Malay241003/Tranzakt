# ---------------------------------------------------------------------------
# bank-webhook (Express) environment
# ---------------------------------------------------------------------------
# NOTE: For the hosted demo this standalone service is OPTIONAL and is NOT
# deployed. The user-app now credits the wallet directly on "Add Money"
# (see apps/user-app/app/lib/actions/createOnrampTransaction.ts). This service
# is kept only for local experimentation with the original webhook flow.

# Shared secret the (simulated) bank must send in the webhook payload to be
# authorized. Must match the `secret` field POSTed to /hdfcWebhook.
HDFC_WEBHOOK_SECRET="replace-with-a-shared-secret"

# This service also needs DATABASE_URL (read from packages/db/.env via Prisma)
# if you run it locally.
