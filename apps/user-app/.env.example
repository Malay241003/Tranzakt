# ---------------------------------------------------------------------------
# user-app (Next.js) environment
# ---------------------------------------------------------------------------

# Secret used to sign NextAuth session JWTs. Use a long random string.
# Generate one with:  openssl rand -base64 32
JWT_SECRET="replace-with-a-long-random-secret"

# Full public URL the app is served from (NO trailing slash).
#   Local:      http://localhost:3001
#   Production: https://your-app.onrender.com
NEXTAUTH_URL="http://localhost:3001"

# Database. The Next.js process loads env from THIS file (apps/user-app/.env),
# so Prisma Client needs DATABASE_URL here too (same value as packages/db/.env).
# In production (Render) set it as a service Environment Variable instead.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Phone number of the seeded "demo recipient" wallet shown on the P2P page so
# visitors can send a test payment without making a second account. Must match
# the user seeded by packages/db/prisma/seed-demo.cjs. NEXT_PUBLIC_ = exposed to
# the browser. Leave empty to hide the hint.
NEXT_PUBLIC_DEMO_RECIPIENT="9876543210"

# ---------------------------------------------------------------------------
# Keep-alive self-ping (see instrumentation.ts)
# ---------------------------------------------------------------------------
# In production the app pings its own /api/health every 10 min so Render's free
# tier doesn't spin it down. Disable it locally:
DISABLE_SELF_PING="true"
# Optional explicit URL to ping. Falls back to NEXTAUTH_URL, then to Render's
# auto-provided RENDER_EXTERNAL_URL.
# SELF_PING_URL="https://your-app.onrender.com"
